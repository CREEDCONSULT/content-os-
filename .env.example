# Application
APP_ENV=development
APP_NAME=Mezie BrandOS
APP_BASE_URL=http://localhost:3100
API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3100
BRANDOS_WEB_PORT=3100
LOG_LEVEL=INFO

# Database
POSTGRES_DB=mezie_brandos
POSTGRES_USER=brandos
POSTGRES_PASSWORD=brandos_local_only
DATABASE_URL=postgresql+psycopg://brandos:brandos_local_only@postgres:5432/mezie_brandos

# Single-founder authentication
AUTH_MODE=local
AUTH_USERNAME=mezie
AUTH_PASSWORD=brandos-local-dev
SESSION_SECRET=brandos-local-session-secret-change-me

# Local storage and vault
OBJECT_STORAGE_PATH=/app/storage
BRANDOS_VAULT_PATH=/app/vault
MAX_UPLOAD_MB=250

# AI provider aliases. Model names stay configurable.
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_SECONDS=60
BRAND_QUALITY_MODEL=
BRAND_FAST_MODEL=
BRAND_VISION_MODEL=
BRAND_TRANSCRIPTION_MODEL=
BRAND_EMBEDDING_MODEL=
DAILY_MODEL_BUDGET_USD=1.00
WEEKLY_RESEARCH_BUDGET_USD=5.00

# Telegram
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ALLOWED_USER_IDS=

# Creator intelligence / Apify
APIFY_ENABLED=false
APIFY_TOKEN=
APIFY_APPROVED_ACTOR_IDS=
APIFY_DAILY_BUDGET_USD=0

# Optional read-only CreedAI Memory API adapter
CREED_MEMORY_ENABLED=false
CREED_MEMORY_URL=http://host.docker.internal:8788
CREEDAI_MEMORY_API_KEY=
CREED_MEMORY_SCOPE=founder
